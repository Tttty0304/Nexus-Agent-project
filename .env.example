# ============================================
# Nexus-Agent 环境变量配置示例（满血版本）
# ============================================
# 复制此文件为 .env 并修改配置值
# cp .env.example .env

# ===== 应用基础配置 =====
APP_NAME=Nexus-Agent
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# ===== 服务器配置 =====
HOST=0.0.0.0
PORT=8080
WORKERS=2

# ===== vLLM 服务配置 (本地 Qwen-7B-AWQ 模型) =====
# Docker Compose 方式: http://vllm:8001
# 本地启动方式: http://localhost:8001
VLLM_BASE_URL=http://localhost:8001
VLLM_API_KEY=nexus-agent-secret-key
VLLM_MODEL=Qwen2-7B-Instruct-AWQ
VLLM_MAX_CONCURRENT=20
VLLM_TIMEOUT=60.0

# ===== 数据库配置（PostgreSQL + pgvector）=====
# 格式：postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/nexus
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

# ===== Redis 配置 =====
# 格式：redis://host:port/db
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=50

# ===== Celery 配置 =====
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_WORKER_CONCURRENCY=4

# ===== 安全配置（JWT）=====
# ⚠️ 生产环境必须修改！
SECRET_KEY=your-secret-key-change-in-production-minimum-32-characters-long
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== 限流配置 =====
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_CAPACITY=60
RATE_LIMIT_BURST=10

# ===== 会话配置 =====
MAX_SESSION_ROUNDS=10
SESSION_TTL_DAYS=7

# ===== RAG 配置 =====
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DIMENSION=1024
EMBEDDING_DEVICE=cpu
CHUNK_SIZE=512
CHUNK_OVERLAP=50
VECTOR_TOP_K=10
VECTOR_THRESHOLD=0.7

# ===== Agent 配置 =====
AGENT_MAX_ITERATIONS=5
AGENT_TIMEOUT_SECONDS=30.0

# ===== 监控配置（可选）=====
METRICS_ENABLED=true
METRICS_PORT=9090

# ===== Grafana 配置（可选）=====
GRAFANA_PASSWORD=admin
